---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import BlogInterface from '../components/BlogInterface';
import { Cpu } from 'lucide-react';

// Fetching posts using the modern Vite-native glob
const postFiles = import.meta.glob('./posts/*.md', { eager: true });

const formattedPosts = Object.values(postFiles).map((post: any) => ({
  title: post.frontmatter.title,
  date: post.frontmatter.pubDate,
  slug: post.url, 
  category: post.frontmatter.category,
  excerpt: post.frontmatter.description
})).sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Layout title="Digital Archives">
  <div class="fixed inset-0 z-0 bg-[#050810]">
    <div class="absolute inset-0 z-10 bg-[url('/noise.svg')] opacity-[0.03] pointer-events-none"></div>
    <div class="absolute inset-0 z-20 bg-gradient-to-b from-transparent via-transparent to-[#050810]/60 pointer-events-none"></div>
  </div>

  <Navbar />

  <main class="relative z-30 w-full min-h-screen pt-32 pb-40 px-[6vw]">
    <div class="max-w-[1700px] mx-auto">
      
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 border-b border-white/10 pb-8 backdrop-blur-md gap-8">
        <div class="text-left">
          <div class="flex items-center gap-2 mb-3">
            <div class="h-1.5 w-1.5 bg-blue-500 rounded-full animate-pulse shadow-[0_0_8px_#3b82f6]"></div>
            <span class="text-[10px] font-mono uppercase tracking-[0.5em] text-blue-400 font-black">Memory_Sectors_Active</span>
          </div>
          <h1 class="text-white text-5xl md:text-7xl font-black uppercase italic tracking-tighter leading-none">
            System <span class="text-blue-400">Logs</span>
          </h1>
        </div>
        <div class="text-right font-mono text-[10px] text-white/30 uppercase tracking-[0.3em]">
            Status: Uplink_Stable <br/>
            Location: src/pages/posts
        </div>
      </div>

      {formattedPosts.length > 0 ? (
        <BlogInterface client:load initialPosts={formattedPosts} />
      ) : (
        <div class="flex flex-col items-center justify-center py-40 border border-dashed border-white/10 rounded-[3rem]">
            <Cpu className="text-white/10 mb-4 animate-pulse" size={48} />
            <p class="text-white/20 font-mono uppercase tracking-widest">No_Data_Packets_Detected</p>
        </div>
      )}

    </div>
  </main>
</Layout>

<style is:global>
  /* V4 FIX: Point this path to your actual global.css 
     This allows Tailwind to "see" your theme variables 
  */
  @reference "../styles/global.css"; 

  .prose h1, .prose h2, .prose h3 {
    @apply text-white uppercase italic font-black tracking-tighter mt-12 mb-6;
  }
  .prose p {
    @apply text-white/70 font-mono leading-relaxed mb-6;
  }
  
  /* Additional fix for prose links if you use them */
  .prose a {
    @apply text-blue-400 underline decoration-blue-500/30 hover:text-blue-300 transition-colors;
  }
</style>